{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/register", "dest": "/server.js" },
    { "src": "/login", "dest": "/server.js" },
    { "src": "/book", "dest": "/server.js" },
    { "src": "/review", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}